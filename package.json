{
  "name": "@octocloud/types",
  "version": "1.5.38",
  "description": "",
  "license": "ISC",
  "author": "",
  "homepage": "https://github.com/octotravel/octo-types#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/octotravel/octo-types.git"
  },
  "bugs": {
    "url": "https://github.com/octotravel/octo-types/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "build:dry": "tsc --noEmit",
    "build:dry:ci": "tsc --noEmit",
    "check": "npm run build:dry && npm run format && npm run lint",
    "fix": "biome check --write .",
    "format": "biome format",
    "format:fix": "biome format --write .",
    "lint": "biome lint",
    "lint:fix": "biome lint --write .",
    "test": "",
    "lefthook": "lefthook install",
    "audit": "audit-ci --config ./audit-ci.json",
    "prepare": "npm run build",
    "generate:types-codegen": "openapi --input src/open-api/openapi.yaml --output src/open-api/codegen --client none",
    "generate:types-codegen-models": "openapi --input src/open-api/openapi.yaml --output src/open-api/codegen-only-models/ --exportCore false --exportServices false --client none",
    "generate:types-typescript": "openapi-typescript src/open-api/openapi.yaml --output src/open-api/typescript/types.ts",
    "generate:zod-schemas": "openapi-zod-client src/open-api/openapi.yaml --o src/open-api/zod-openapi/schemas.ts --export-schemas false",
    "generate:zod": "ts-to-zod src/open-api/codegen-only-models/models/AvailabilityCalendar.ts src/open-api/ts-to-zod/AvailabilityCalendarSchema.ts",
    "generate:zod-all": "ts-to-zod src/open-api/codegen-only-models/index.ts src/open-api/ts-to-zod/schema.ts"
  },
  "types": "dist/index.d.ts",
  "dependencies": {
    "@adyen/adyen-web": "6.14.0",
    "yup": "0.32.11",
    "zod": "^3.25.61"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.9.0",
    "audit-ci": "7.1.0",
    "glob": "^11.0.3",
    "lefthook": "1.10.10",
    "openapi-typescript": "^7.8.0",
    "openapi-typescript-codegen": "^0.29.0",
    "openapi-zod-client": "^1.18.3",
    "ts-node": "^10.9.2",
    "ts-to-zod": "^3.15.0",
    "typescript": "^5.7.2"
  }
}
